{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "dev", "casual"] },
        "disabled": { "type": "boolean" },
        "deleted": { "type": "boolean" },
        "maintenance": { "type": "boolean" },
        "settings": {
          "type": "object",
          "properties": {
            "punctuation": { "type": "string", "enum": ["none", "basic", "intermediate"] },
            "wordCount": { "type": "number" },
            "wordDifficulty": { "type": "string", "enum": ["basic", "intermediate", "advanced"] },
            "capitalLetters": { "type": "boolean" },
            "visualKeyboard": { "type": "boolean" },
            "errorMode": { "type": "string", "enum": ["free", "word", "letter"] }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Session": {
      "title": "Session",
      "description": "A typing test session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "wpm": { "type": "number" },
        "accuracy": { "type": "number" },
        "settings": {
          "type": "object",
          "properties": {
            "punctuation": { "type": "string" },
            "wordCount": { "type": "number" },
            "wordDifficulty": { "type": "string" },
            "capitalLetters": { "type": "boolean" },
            "visualKeyboard": { "type": "boolean" },
            "errorMode": { "type": "string" }
          }
        }
      },
      "required": ["id", "userId", "date", "wpm", "accuracy"]
    },
    "Record": {
      "title": "Record",
      "description": "A manually added record from another website",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "website": { "type": "string" },
        "wpm": { "type": "number" },
        "accuracy": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "website", "wpm", "accuracy", "date"]
    },
    "Note": {
      "title": "Note",
      "description": "A note created by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "pinned": { "type": "boolean" },
        "updatedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "content", "pinned", "updatedAt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and their preferences."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Stores typing sessions for a user."
    },
    "/users/{userId}/records/{recordId}": {
      "schema": { "$ref": "#/entities/Record" },
      "description": "Stores manually added records for a user."
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores notes for a user."
    }
  }
}
